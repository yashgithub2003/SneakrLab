<%- include('./partials/header') %>

    <div class="min-h-screen flex flex-col">
        <div class="container mx-auto px-4 sm:px-6 lg:px-10 py-20 lg:py-24 flex flex-col lg:flex-row flex-grow gap-6">
            
            <!-- Sidebar Navigation -->
            <aside class="w-full lg:w-[25%] flex flex-col items-start bg-zinc-800/30 backdrop-blur-sm rounded-lg p-6 border border-zinc-700/50 lg:sticky lg:top-24 h-fit">
                <h3 class="text-gray-300 font-semibold text-sm uppercase tracking-wide mb-4">
                    <i class="ri-dashboard-line mr-2"></i>Admin Panel
                </h3>
                <div class="flex flex-col w-full">
                    <a class="block w-full mb-3 text-gray-400 hover:text-orange-500 hover:bg-zinc-700/50 px-3 py-2 rounded-md transition duration-300 text-sm" href="/admin/products">
                        <i class="ri-shopping-bag-line mr-2"></i>All Products
                    </a>
                    <a class="block w-full mb-3 text-gray-400 hover:text-orange-500 hover:bg-zinc-700/50 px-3 py-2 rounded-md transition duration-300 text-sm" href="/products/create">
                        <i class="ri-add-circle-line mr-2"></i>Create New Product
                    </a>
                    <a class="block w-full mb-3 text-orange-500 bg-zinc-700/50 px-3 py-2 rounded-md transition duration-300 text-sm font-semibold" href="/admin/inventory">
                        <i class="ri-stack-line mr-2"></i>Inventory Management
                    </a>
                    <a class="block w-full mb-3 text-gray-400 hover:text-orange-500 hover:bg-zinc-700/50 px-3 py-2 rounded-md transition duration-300 text-sm" href="/admin/orders">
                        <i class="ri-file-list-line mr-2"></i>Orders
                    </a>
                </div>
            </aside>

            <!-- Main Content Area -->
            <main class="w-full lg:w-3/4">
                <div class="bg-zinc-800/40 backdrop-blur-sm p-6 sm:p-8 shadow-xl rounded-lg border border-zinc-700/50">
                    <h2 class="text-xl sm:text-2xl font-bold text-white mb-6">
                        <i class="ri-edit-box-line mr-2 text-orange-500"></i>Edit Inventory Item
                    </h2>

                    <!-- Product Preview -->
                    <div class="bg-zinc-700/30 rounded-lg p-4 mb-6 flex items-center gap-4 border border-zinc-700">
                        <img class="w-20 h-20 object-contain bg-zinc-700 rounded-md p-2" 
                             src="data:image/jpeg;base64,<%= inventoryItem.product.image.toString('base64') %>" 
                             alt="<%= inventoryItem.product.name %>">
                        <div>
                            <h3 class="text-white font-semibold text-lg"><%= inventoryItem.product.name %></h3>
                            <p class="text-gray-400 text-sm"><%= inventoryItem.product.brand || 'No Brand' %></p>
                            <p class="text-orange-500 text-sm font-bold mt-1">₹ <%= inventoryItem.product.price.toLocaleString('en-IN') %></p>
                        </div>
                    </div>

                    <form autocomplete="off" action="/admin/inventory/update/<%= inventoryItem._id %>" method="post">
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 mb-6">
                            <!-- Size -->
                            <div>
                                <label class="block mb-2 font-medium text-gray-300 text-sm">Size *</label>
                                <input 
                                    name="size" 
                                    type="text" 
                                    value="<%= inventoryItem.size %>"
                                    required
                                    class="w-full border border-zinc-600 bg-zinc-700/50 p-3 rounded-lg text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-transparent transition duration-300 text-sm">
                            </div>

                            <!-- Stock -->
                            <div>
                                <label class="block mb-2 font-medium text-gray-300 text-sm">Stock Quantity *</label>
                                <input 
                                    name="stock" 
                                    type="number" 
                                    value="<%= inventoryItem.stock %>"
                                    required
                                    min="0"
                                    class="w-full border border-zinc-600 bg-zinc-700/50 p-3 rounded-lg text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-transparent transition duration-300 text-sm">
                            </div>
                        </div>

                        <!-- Stock Status Indicator -->
                        <div class="mb-6 p-4 rounded-lg border border-zinc-700 bg-zinc-700/20">
                            <h4 class="text-gray-300 text-sm font-semibold mb-3">Current Status</h4>
                            <div class="flex items-center gap-3">
                                <% if(inventoryItem.stock === 0) { %>
                                    <span class="inline-block bg-red-500/20 text-red-400 px-4 py-2 rounded-full text-sm font-semibold">
                                        <i class="ri-close-circle-line mr-1"></i>Out of Stock
                                    </span>
                                <% } else if(inventoryItem.stock <= 5) { %>
                                    <span class="inline-block bg-yellow-500/20 text-yellow-400 px-4 py-2 rounded-full text-sm font-semibold">
                                        <i class="ri-alert-line mr-1"></i>Low Stock
                                    </span>
                                <% } else { %>
                                    <span class="inline-block bg-green-500/20 text-green-400 px-4 py-2 rounded-full text-sm font-semibold">
                                        <i class="ri-checkbox-circle-line mr-1"></i>In Stock
                                    </span>
                                <% } %>
                                <span class="text-gray-400 text-sm">
                                    Last updated: <%= new Date(inventoryItem.updatedAt).toLocaleDateString('en-IN') %>
                                </span>
                            </div>
                        </div>

                        <!-- Action Buttons -->
                        <div class="flex flex-col sm:flex-row gap-3 pt-4 border-t border-zinc-700">
                            <button 
                                type="submit"
                                class="w-full sm:w-auto px-6 py-3 rounded-lg bg-orange-600 text-white font-semibold hover:bg-orange-500 transition duration-300 transform hover:scale-105 active:scale-95 shadow-lg">
                                <i class="ri-save-line mr-2"></i>Update Inventory
                            </button>
                            <a href="/admin/inventory"
                                class="w-full sm:w-auto px-6 py-3 rounded-lg bg-zinc-700 text-white font-semibold hover:bg-zinc-600 transition duration-300 text-center">
                                <i class="ri-arrow-left-line mr-2"></i>Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </main>

        </div>
    </div>

<%- include('./partials/footer') %>
