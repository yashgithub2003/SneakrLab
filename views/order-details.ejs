<%- include('./partials/header') %>

<div class="w-full min-h-screen px-4 sm:px-8 lg:px-20 py-20 lg:py-24">
    <div class="max-w-6xl mx-auto">
        
        <!-- Back Button -->
        <div class="mb-6">
            <a href="/owners/orders" class="inline-flex items-center text-gray-400 hover:text-orange-500 transition duration-300">
                <i class="ri-arrow-left-line mr-2"></i>
                Back to Orders
            </a>
        </div>

        <!-- Order Header -->
        <div class="bg-zinc-800/60 backdrop-blur-sm rounded-lg border border-zinc-700 p-6 sm:p-8 shadow-xl mb-6">
            <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 mb-6">
                <div>
                    <h1 class="text-2xl sm:text-3xl font-bold text-white mb-2">
                        Order Details
                    </h1>
                    <p class="text-gray-400 text-sm">
                        Order #<%= order._id.toString().slice(-8).toUpperCase() %>
                    </p>
                </div>
                
                <div class="flex flex-col sm:flex-row gap-3">
                    <!-- Order Status Badge -->
                    <span class="inline-block px-4 py-2 rounded-full text-sm font-semibold text-center
                        <% if(order.orderStatus === 'PROCESSING') { %>
                            bg-blue-500/20 text-blue-400
                        <% } else if(order.orderStatus === 'SHIPPED') { %>
                            bg-purple-500/20 text-purple-400
                        <% } else if(order.orderStatus === 'DELIVERED') { %>
                            bg-green-500/20 text-green-400
                        <% } else if(order.orderStatus === 'CANCELLED') { %>
                            bg-red-500/20 text-red-400
                        <% } %>">
                        <i class="
                            <% if(order.orderStatus === 'PROCESSING') { %>
                                ri-time-line
                            <% } else if(order.orderStatus === 'SHIPPED') { %>
                                ri-truck-line
                            <% } else if(order.orderStatus === 'DELIVERED') { %>
                                ri-checkbox-circle-line
                            <% } else if(order.orderStatus === 'CANCELLED') { %>
                                ri-close-circle-line
                            <% } %>
                            mr-1"></i>
                        <%= order.orderStatus %>
                    </span>

                    <!-- Payment Status Badge -->
                    <span class="inline-block px-4 py-2 rounded-full text-sm font-semibold text-center
                        <% if(order.paymentStatus === 'PAID') { %>
                            bg-green-500/20 text-green-400
                        <% } else if(order.paymentStatus === 'PENDING') { %>
                            bg-yellow-500/20 text-yellow-400
                        <% } else if(order.paymentStatus === 'FAILED') { %>
                            bg-red-500/20 text-red-400
                        <% } %>">
                        Payment: <%= order.paymentStatus %>
                    </span>
                </div>
            </div>

            <!-- Order Timeline -->
            <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 pt-4 border-t border-zinc-700">
                <div>
                    <p class="text-gray-400 text-xs mb-1">Order Placed</p>
                    <p class="text-white text-sm font-semibold">
                        <%= new Date(order.createdAt).toLocaleDateString('en-IN', { 
                            day: 'numeric',
                            month: 'short',
                            year: 'numeric'
                        }) %>
                    </p>
                </div>
                <div>
                    <p class="text-gray-400 text-xs mb-1">Total Amount</p>
                    <p class="text-orange-500 text-sm font-bold">₹ <%= order.totalAmount.toLocaleString('en-IN') %></p>
                </div>
                <div>
                    <p class="text-gray-400 text-xs mb-1">Payment Method</p>
                    <p class="text-white text-sm font-semibold"><%= order.paymentMethod %></p>
                </div>
                <div>
                    <p class="text-gray-400 text-xs mb-1">Items</p>
                    <p class="text-white text-sm font-semibold"><%= order.items.length %> item<%= order.items.length !== 1 ? 's' : '' %></p>
                </div>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
            
            <!-- Left Section - Order Items & Shipping -->
            <div class="lg:col-span-2 space-y-6">
                
                <!-- Order Items -->
                <div class="bg-zinc-800/60 backdrop-blur-sm rounded-lg border border-zinc-700 p-6 sm:p-8 shadow-xl">
                    <h2 class="text-xl font-bold text-white mb-6 border-b border-zinc-700 pb-3">
                        <i class="ri-shopping-bag-line mr-2 text-orange-500"></i>Order Items
                    </h2>

                    <div class="space-y-4">
                        <% order.items.forEach(function(item) { %>
                            <div class="flex items-start gap-4 p-4 bg-zinc-700/30 rounded-lg border border-zinc-700 hover:border-orange-500/50 transition duration-300">
                                <img class="w-20 h-20 sm:w-24 sm:h-24 object-contain bg-zinc-700 rounded-md p-2" 
                                     src="data:image/jpeg;base64,<%= item.product.image.toString('base64') %>" 
                                     alt="<%= item.product.name %>">
                                
                                <div class="flex-1">
                                    <h3 class="text-white font-semibold text-base sm:text-lg mb-2">
                                        <%= item.product.name %>
                                    </h3>
                                    
                                    <% if(item.product.brand) { %>
                                        <p class="text-gray-400 text-sm mb-2">
                                            <i class="ri-price-tag-3-line mr-1"></i>
                                            <%= item.product.brand %>
                                        </p>
                                    <% } %>
                                    
                                    <div class="flex items-center gap-4 text-sm text-gray-400 mb-3">
                                        <span>
                                            <i class="ri-ruler-line mr-1"></i>
                                            Size: <span class="text-white font-medium"><%= item.size %></span>
                                        </span>
                                        <span>•</span>
                                        <span>
                                            <i class="ri-stack-line mr-1"></i>
                                            Qty: <span class="text-white font-medium"><%= item.quantity %></span>
                                        </span>
                                    </div>

                                    <div class="flex items-center justify-between">
                                        <div>
                                            <p class="text-orange-500 font-bold text-lg">
                                                ₹ <%= (item.price * item.quantity).toLocaleString('en-IN') %>
                                            </p>
                                            <p class="text-gray-500 text-xs">
                                                ₹ <%= item.price.toLocaleString('en-IN') %> × <%= item.quantity %>
                                            </p>
                                        </div>

                                        <% if(order.orderStatus === 'DELIVERED') { %>
                                            <a href="/products/<%= item.product._id %>/review" 
                                               class="text-sm text-orange-500 hover:text-orange-400 font-medium">
                                                <i class="ri-star-line mr-1"></i>Write Review
                                            </a>
                                        <% } %>
                                    </div>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                </div>

                <!-- Shipping Address -->
                <div class="bg-zinc-800/60 backdrop-blur-sm rounded-lg border border-zinc-700 p-6 sm:p-8 shadow-xl">
                    <h2 class="text-xl font-bold text-white mb-6 border-b border-zinc-700 pb-3">
                        <i class="ri-map-pin-line mr-2 text-orange-500"></i>Shipping Address
                    </h2>

                    <div class="bg-zinc-700/30 p-4 rounded-lg border border-zinc-700">
                        <p class="text-white font-semibold text-lg mb-3">
                            <%= order.shippingAddress.fullName %>
                        </p>
                        
                        <div class="space-y-2 text-gray-400 text-sm">
                            <p class="flex items-start">
                                <i class="ri-map-pin-2-line mr-2 mt-0.5 text-orange-500"></i>
                                <span><%= order.shippingAddress.address %></span>
                            </p>
                            
                            <p class="flex items-center">
                                <i class="ri-building-line mr-2 text-orange-500"></i>
                                <%= order.shippingAddress.city %>, <%= order.shippingAddress.postalCode %>
                            </p>
                            
                            <p class="flex items-center">
                                <i class="ri-global-line mr-2 text-orange-500"></i>
                                <%= order.shippingAddress.country %>
                            </p>
                        </div>
                    </div>
                </div>

            </div>

            <!-- Right Section - Summary & Actions -->
            <div class="lg:col-span-1 space-y-6">
                
                <!-- Order Summary -->
                <div class="bg-zinc-800/60 backdrop-blur-sm rounded-lg border border-zinc-700 p-6 shadow-xl lg:sticky lg:top-24">
                    <h2 class="text-lg font-bold text-white mb-4 border-b border-zinc-700 pb-3">
                        <i class="ri-file-list-line mr-2 text-orange-500"></i>Order Summary
                    </h2>

                    <% 
                        let subtotal = 0;
                        order.items.forEach(item => {
                            subtotal += item.price * item.quantity;
                        });
                        let platformFee = 20;
                        let shipping = 0;
                    %>

                    <div class="space-y-3 mb-4">
                        <div class="flex justify-between text-sm">
                            <span class="text-gray-400">Subtotal</span>
                            <span class="text-white">₹ <%= subtotal.toLocaleString('en-IN') %></span>
                        </div>
                        
                        <div class="flex justify-between text-sm">
                            <span class="text-gray-400">Platform Fee</span>
                            <span class="text-white">₹ <%= platformFee %></span>
                        </div>
                        
                        <div class="flex justify-between text-sm">
                            <span class="text-gray-400">Shipping</span>
                            <span class="text-green-500 font-semibold">FREE</span>
                        </div>
                    </div>

                    <div class="border-t border-zinc-700 pt-4 mb-6">
                        <div class="flex justify-between items-center">
                            <span class="text-white font-bold">Total</span>
                            <span class="text-orange-500 font-bold text-2xl">
                                ₹ <%= order.totalAmount.toLocaleString('en-IN') %>
                            </span>
                        </div>
                    </div>

                    <!-- Payment Info -->
                    <div class="p-4 bg-zinc-700/30 rounded-lg border border-zinc-700 mb-6">
                        <h3 class="text-white font-semibold text-sm mb-2 flex items-center">
                            <% if(order.paymentMethod === 'COD') { %>
                                <i class="ri-money-rupee-circle-line mr-2 text-orange-500"></i>
                                Cash on Delivery
                            <% } else if(order.paymentMethod === 'CARD') { %>
                                <i class="ri-bank-card-2-line mr-2 text-orange-500"></i>
                                Card Payment
                            <% } else if(order.paymentMethod === 'UPI') { %>
                                <i class="ri-smartphone-line mr-2 text-orange-500"></i>
                                UPI Payment
                            <% } %>
                        </h3>
                        <p class="text-gray-400 text-xs">
                            Status: 
                            <span class="<%= order.paymentStatus === 'PAID' ? 'text-green-400' : order.paymentStatus === 'PENDING' ? 'text-yellow-400' : 'text-red-400' %> font-semibold">
                                <%= order.paymentStatus %>
                            </span>
                        </p>
                    </div>

                    <!-- Action Buttons -->
                    <div class="space-y-3">
                        <% if(order.orderStatus === 'PROCESSING') { %>
                            <a href="/orders/cancel/<%= order._id %>" 
                               onclick="return confirm('Are you sure you want to cancel this order?')"
                               class="block w-full py-3 bg-red-600 hover:bg-red-500 text-white font-semibold rounded-lg transition duration-300 text-center">
                                <i class="ri-close-circle-line mr-2"></i>Cancel Order
                            </a>
                        <% } %>

                        <% if(order.orderStatus === 'SHIPPED' || order.orderStatus === 'DELIVERED') { %>
                            <button class="block w-full py-3 bg-orange-600 hover:bg-orange-500 text-white font-semibold rounded-lg transition duration-300">
                                <i class="ri-map-pin-line mr-2"></i>Track Order
                            </button>
                        <% } %>

                        <button onclick="window.print()" class="block w-full py-3 bg-zinc-700 hover:bg-zinc-600 text-white font-semibold rounded-lg transition duration-300">
                            <i class="ri-printer-line mr-2"></i>Print Invoice
                        </button>
                    </div>

                    <!-- Help Section -->
                    <div class="mt-6 p-4 bg-blue-500/10 border border-blue-500/30 rounded-lg">
                        <p class="text-blue-400 text-xs mb-2 font-semibold">
                            <i class="ri-customer-service-line mr-1"></i>Need Help?
                        </p>
                        <p class="text-gray-400 text-xs">
                            Contact our support team for any order-related queries
                        </p>
                        <a href="/support" class="text-blue-400 text-xs hover:underline mt-2 inline-block">
                            Get Support →
                        </a>
                    </div>
                </div>

            </div>

        </div>

    </div>
</div>

<%- include('./partials/footer') %>
