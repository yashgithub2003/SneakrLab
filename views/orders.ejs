<%- include('./partials/header') %>

<div class="max-w-6xl mx-auto px-6 py-16">

    <h1 class="text-3xl font-bold text-white mb-10">
        My Orders
    </h1>

    <% if (orders.length > 0) { %>

        <% orders.forEach(function(order) { %>

            <div class="bg-zinc-800 p-6 rounded-lg mb-6 shadow-md">

                <div class="flex justify-between items-center mb-4">

                    <div>
                        <p class="text-gray-400 text-sm">
                            Order ID
                        </p>
                        <p class="text-white font-medium">
                            <%= order._id %>
                        </p>
                    </div>

                    <div class="text-right">
                        <p class="text-gray-400 text-sm">
                            Date
                        </p>
                        <p class="text-white">
                            <%= order.createdAt.toDateString() %>
                        </p>
                    </div>

                </div>

                <div class="flex justify-between items-center">

                    <div>
                        <p class="text-gray-300 text-sm">
                            Status:
                            <span class="text-orange-500 font-semibold">
                                <%= order.orderStatus %>
                            </span>
                        </p>

                        <p class="text-gray-300 text-sm">
                            Payment:
                            <%= order.paymentMethod %>
                            (<%= order.paymentStatus %>)
                        </p>
                    </div>

                    <div class="text-right">
                        <p class="text-orange-500 font-bold text-lg">
                            ₹ <%= order.totalAmount.toLocaleString('en-IN') %>
                        </p>

                        <a href="/owners/orders/<%= order._id %>" 
                           class="inline-block mt-2 text-sm text-blue-400 hover:underline">
                            View Details →
                        </a>
                    </div>

                </div>

            </div>

        <% }); %>

    <% } else { %>

        <div class="bg-zinc-800 p-10 rounded-lg text-center">
            <p class="text-gray-400 text-lg">
                You have not placed any orders yet.
            </p>
        </div>

    <% } %>

</div>

<%- include('./partials/footer') %>
