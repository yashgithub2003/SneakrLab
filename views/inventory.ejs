<%- include('./partials/header') %>

    <!-- Success Message -->
    <% if(success && success.length > 0){ %>
        <div class="fixed top-5 left-1/2 -translate-x-1/2 p-3 px-5 rounded-md bg-green-500 z-50 shadow-lg max-w-md mx-4 animate-pulse">
            <span class="inline-block text-white text-sm md:text-base font-medium">
                ✓ <%= success %>
            </span>
        </div>
    <% } %>

    <!-- Error Message -->
    <% if(error && error.length > 0){ %>
        <div class="fixed top-5 left-1/2 -translate-x-1/2 p-3 px-5 rounded-md bg-red-500 z-50 shadow-lg max-w-md mx-4 animate-pulse">
            <span class="inline-block text-white text-sm md:text-base font-medium">
                ⚠️ <%= error %>
            </span>
        </div>
    <% } %>

    <div class="min-h-screen flex flex-col">
        <div class="container mx-auto px-4 sm:px-6 lg:px-10 py-20 lg:py-24 flex flex-col lg:flex-row flex-grow gap-6">
            
            <!-- Sidebar Navigation -->
            <aside class="w-full lg:w-[25%] flex flex-col items-start bg-zinc-800/30 backdrop-blur-sm rounded-lg p-6 border border-zinc-700/50 lg:sticky lg:top-24 h-fit">
                <h3 class="text-gray-300 font-semibold text-sm uppercase tracking-wide mb-4">
                    <i class="ri-dashboard-line mr-2"></i>Admin Panel
                </h3>
                <div class="flex flex-col w-full">
                    <a class="block w-full mb-3 text-gray-400 hover:text-orange-500 hover:bg-zinc-700/50 px-3 py-2 rounded-md transition duration-300 text-sm" href="/admin/products">
                        <i class="ri-shopping-bag-line mr-2"></i>All Products
                    </a>
                    <a class="block w-full mb-3 text-gray-400 hover:text-orange-500 hover:bg-zinc-700/50 px-3 py-2 rounded-md transition duration-300 text-sm" href="/products/create">
                        <i class="ri-add-circle-line mr-2"></i>Create New Product
                    </a>
                    <a class="block w-full mb-3 text-orange-500 bg-zinc-700/50 px-3 py-2 rounded-md transition duration-300 text-sm font-semibold" href="/admin/inventory">
                        <i class="ri-stack-line mr-2"></i>Inventory Management
                    </a>
                    <a class="block w-full mb-3 text-gray-400 hover:text-orange-500 hover:bg-zinc-700/50 px-3 py-2 rounded-md transition duration-300 text-sm" href="/admin/orders">
                        <i class="ri-file-list-line mr-2"></i>Orders
                    </a>
                    <a class="block w-full mb-3 text-gray-400 hover:text-orange-500 hover:bg-zinc-700/50 px-3 py-2 rounded-md transition duration-300 text-sm" href="/admin/users">
                        <i class="ri-user-line mr-2"></i>Users
                    </a>
                </div>
            </aside>

            <!-- Main Content Area -->
            <main class="w-full lg:w-3/4 flex flex-col gap-6">
                
                <!-- Add New Inventory Item -->
                <div class="bg-zinc-800/40 backdrop-blur-sm p-6 sm:p-8 shadow-xl rounded-lg border border-zinc-700/50">
                    <h2 class="text-xl sm:text-2xl font-bold text-white mb-6">
                        <i class="ri-add-box-line mr-2 text-orange-500"></i>Add Inventory Stock
                    </h2>

                    <form autocomplete="off" action="/owners/inventory/add" method="post">
                        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
                            <!-- Product Selection -->
                            <div class="sm:col-span-2">
                                <label class="block mb-2 font-medium text-gray-300 text-sm">Select Product *</label>
                                <select 
                                    name="productId" 
                                    required
                                    class="w-full bg-zinc-700/50 border border-zinc-600 rounded-lg px-3 py-3 text-white text-sm focus:outline-none focus:ring-2 focus:ring-orange-500 transition duration-300 cursor-pointer">
                                    <option value="">Choose a product...</option>
                                    <% products.forEach(function(product) { %>
                                        <option value="<%= product._id %>"><%= product.name %> - <%= product.brand || 'No Brand' %></option>
                                    <% }) %>
                                </select>
                            </div>

                            <!-- Size -->
                            <div>
                                <label class="block mb-2 font-medium text-gray-300 text-sm">Size *</label>
                                <input 
                                    name="size" 
                                    type="text" 
                                    placeholder="e.g., UK 8, EU 42"
                                    required
                                    class="w-full border border-zinc-600 bg-zinc-700/50 p-3 rounded-lg text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-transparent transition duration-300 text-sm">
                            </div>

                            <!-- Stock -->
                            <div>
                                <label class="block mb-2 font-medium text-gray-300 text-sm">Stock Quantity *</label>
                                <input 
                                    name="stock" 
                                    type="number" 
                                    placeholder="0"
                                    required
                                    min="0"
                                    value="0"
                                    class="w-full border border-zinc-600 bg-zinc-700/50 p-3 rounded-lg text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-transparent transition duration-300 text-sm">
                            </div>
                        </div>

                        <div class="flex gap-3 mt-6">
                            <button 
                                type="submit"
                                class="px-6 py-3 rounded-lg bg-orange-600 text-white font-semibold hover:bg-orange-500 transition duration-300 transform hover:scale-105 active:scale-95 shadow-lg text-sm">
                                <i class="ri-add-line mr-2"></i>Add to Inventory
                            </button>
                            <button 
                                type="reset"
                                class="px-6 py-3 rounded-lg bg-zinc-700 text-white font-semibold hover:bg-zinc-600 transition duration-300 text-sm">
                                <i class="ri-refresh-line mr-2"></i>Reset
                            </button>
                        </div>
                    </form>
                </div>

                <!-- Current Inventory List -->
                <div class="bg-zinc-800/40 backdrop-blur-sm p-6 sm:p-8 shadow-xl rounded-lg border border-zinc-700/50">
                    <div class="flex items-center justify-between mb-6">
                        <h2 class="text-xl sm:text-2xl font-bold text-white">
                            <i class="ri-list-check-2 mr-2 text-orange-500"></i>Current Inventory
                        </h2>
                        <span class="text-sm text-gray-400">
                            Total Items: <%= inventory.length %>
                        </span>
                    </div>

                    <% if(inventory.length > 0) { %>
                        <!-- Desktop Table View -->
                        <div class="hidden md:block overflow-x-auto">
                            <table class="w-full">
                                <thead>
                                    <tr class="border-b border-zinc-700">
                                        <th class="text-left py-3 px-4 text-gray-300 font-semibold text-sm">Product</th>
                                        <th class="text-left py-3 px-4 text-gray-300 font-semibold text-sm">Brand</th>
                                        <th class="text-center py-3 px-4 text-gray-300 font-semibold text-sm">Size</th>
                                        <th class="text-center py-3 px-4 text-gray-300 font-semibold text-sm">Stock</th>
                                        <th class="text-center py-3 px-4 text-gray-300 font-semibold text-sm">Status</th>
                                        <th class="text-center py-3 px-4 text-gray-300 font-semibold text-sm">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% inventory.forEach(function(item) { %>
                                        <tr class="border-b border-zinc-700/50 hover:bg-zinc-700/20 transition duration-200">
                                            <td class="py-4 px-4">
                                                <div class="flex items-center gap-3">
                                                    <img class="w-12 h-12 object-contain bg-zinc-700 rounded-md p-1" 
                                                         src="data:image/jpeg;base64,<%= item.product.image.toString('base64') %>" 
                                                         alt="<%= item.product.name %>">
                                                    <span class="text-white text-sm font-medium"><%= item.product.name %></span>
                                                </div>
                                            </td>
                                            <td class="py-4 px-4">
                                                <span class="text-gray-400 text-sm"><%= item.product.brand || '-' %></span>
                                            </td>
                                            <td class="py-4 px-4 text-center">
                                                <span class="inline-block bg-zinc-700 text-white px-3 py-1 rounded-full text-sm font-semibold">
                                                    <%= item.size %>
                                                </span>
                                            </td>
                                            <td class="py-4 px-4 text-center">
                                                <span class="text-white font-bold text-sm"><%= item.stock %></span>
                                            </td>
                                            <td class="py-4 px-4 text-center">
                                                <% if(item.stock === 0) { %>
                                                    <span class="inline-block bg-red-500/20 text-red-400 px-3 py-1 rounded-full text-xs font-semibold">
                                                        Out of Stock
                                                    </span>
                                                <% } else if(item.stock <= 5) { %>
                                                    <span class="inline-block bg-yellow-500/20 text-yellow-400 px-3 py-1 rounded-full text-xs font-semibold">
                                                        Low Stock
                                                    </span>
                                                <% } else { %>
                                                    <span class="inline-block bg-green-500/20 text-green-400 px-3 py-1 rounded-full text-xs font-semibold">
                                                        In Stock
                                                    </span>
                                                <% } %>
                                            </td>
                                            <td class="py-4 px-4">
                                                <div class="flex items-center justify-center gap-2">
                                                    <a href="/admin/inventory/edit/<%= item._id %>" 
                                                       class="w-8 h-8 flex items-center justify-center rounded-md bg-blue-500/20 text-blue-400 hover:bg-blue-500 hover:text-white transition duration-300">
                                                        <i class="ri-edit-line"></i>
                                                    </a>
                                                    <a href="/admin/inventory/delete/<%= item._id %>" 
                                                       onclick="return confirm('Are you sure you want to delete this inventory item?')"
                                                       class="w-8 h-8 flex items-center justify-center rounded-md bg-red-500/20 text-red-400 hover:bg-red-500 hover:text-white transition duration-300">
                                                        <i class="ri-delete-bin-line"></i>
                                                    </a>
                                                </div>
                                            </td>
                                        </tr>
                                    <% }) %>
                                </tbody>
                            </table>
                        </div>

                        <!-- Mobile Card View -->
                        <div class="md:hidden space-y-4">
                            <% inventory.forEach(function(item) { %>
                                <div class="bg-zinc-700/30 rounded-lg p-4 border border-zinc-700">
                                    <div class="flex items-start gap-3 mb-3">
                                        <img class="w-16 h-16 object-contain bg-zinc-700 rounded-md p-1" 
                                             src="data:image/jpeg;base64,<%= item.product.image.toString('base64') %>" 
                                             alt="<%= item.product.name %>">
                                        <div class="flex-1">
                                            <h3 class="text-white font-semibold text-sm mb-1"><%= item.product.name %></h3>
                                            <p class="text-gray-400 text-xs"><%= item.product.brand || 'No Brand' %></p>
                                        </div>
                                    </div>
                                    
                                    <div class="grid grid-cols-2 gap-3 mb-3">
                                        <div>
                                            <span class="text-gray-400 text-xs block mb-1">Size</span>
                                            <span class="inline-block bg-zinc-700 text-white px-2 py-1 rounded text-xs font-semibold">
                                                <%= item.size %>
                                            </span>
                                        </div>
                                        <div>
                                            <span class="text-gray-400 text-xs block mb-1">Stock</span>
                                            <span class="text-white font-bold text-sm"><%= item.stock %></span>
                                        </div>
                                    </div>

                                    <div class="flex items-center justify-between">
                                        <% if(item.stock === 0) { %>
                                            <span class="inline-block bg-red-500/20 text-red-400 px-2 py-1 rounded-full text-xs font-semibold">
                                                Out of Stock
                                            </span>
                                        <% } else if(item.stock <= 5) { %>
                                            <span class="inline-block bg-yellow-500/20 text-yellow-400 px-2 py-1 rounded-full text-xs font-semibold">
                                                Low Stock
                                            </span>
                                        <% } else { %>
                                            <span class="inline-block bg-green-500/20 text-green-400 px-2 py-1 rounded-full text-xs font-semibold">
                                                In Stock
                                            </span>
                                        <% } %>

                                        <div class="flex gap-2">
                                            <a href="/admin/inventory/edit/<%= item._id %>" 
                                               class="w-8 h-8 flex items-center justify-center rounded-md bg-blue-500/20 text-blue-400">
                                                <i class="ri-edit-line"></i>
                                            </a>
                                            <a href="/admin/inventory/delete/<%= item._id %>" 
                                               onclick="return confirm('Delete this item?')"
                                               class="w-8 h-8 flex items-center justify-center rounded-md bg-red-500/20 text-red-400">
                                                <i class="ri-delete-bin-line"></i>
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            <% }) %>
                        </div>
                    <% } else { %>
                        <!-- Empty State -->
                        <div class="text-center py-12">
                            <i class="ri-inbox-line text-6xl text-zinc-600 mb-4"></i>
                            <h3 class="text-xl text-gray-400 mb-2">No inventory items yet</h3>
                            <p class="text-sm text-gray-500">Add your first inventory item using the form above</p>
                        </div>
                    <% } %>
                </div>

            </main>

        </div>
    </div>

<%- include('./partials/footer') %>
