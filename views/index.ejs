<%- include('./partials/header') %>

<!-- Error Message - Shows only when error exists -->
<% if(error && error.length > 0){ %>
    <div class="fixed top-5 left-1/2 -translate-x-1/2 p-3 px-5 rounded-md bg-red-500 z-50 shadow-lg max-w-md mx-4 animate-pulse">
        <span class="inline-block text-white text-sm md:text-base font-medium">
            <%= error[0] %>
        </span>
    </div>
<% } %>


    <div class="w-full min-h-screen flex flex-col md:flex-row px-4 sm:px-8 md:px-12 lg:px-20">
        
        <!-- Registration Section - Left Half / Top on Mobile -->
        <div class="w-full md:w-1/2 flex items-center justify-center min-h-[50vh] md:min-h-screen py-8 md:py-10">
            <div class="w-full max-w-md md:max-w-none md:px-8 lg:px-16 xl:px-32">
                <h3 class="text-2xl sm:text-3xl md:text-4xl text-white mb-2">
                    Welcome to <span class="text-orange-500 font-semibold">SneakrLab</span>
                </h3>
                <h4 class="text-lg sm:text-xl md:text-2xl mb-4 md:mb-5 text-gray-300">Create your account</h4>
                
                <form autocomplete="off" action="/users/register" method="post">
                    <input 
                        class="bg-zinc-800 block w-full px-3 py-2.5 md:py-3 border-[1px] rounded-md mb-3 border-zinc-700 text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-transparent transition duration-300 text-sm md:text-base" 
                        type="text" 
                        placeholder="Full Name" 
                        name="fullname"
                        required>
                    
                    <input 
                        class="bg-zinc-800 block w-full px-3 py-2.5 md:py-3 border-[1px] rounded-md mb-3 border-zinc-700 text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-transparent transition duration-300 text-sm md:text-base" 
                        type="email" 
                        placeholder="Email" 
                        name="email"
                        required>
                    
                    <input 
                        class="bg-zinc-800 block w-full px-3 py-2.5 md:py-3 border-[1px] rounded-md mb-3 border-zinc-700 text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-transparent transition duration-300 text-sm md:text-base" 
                        type="password" 
                        placeholder="Password" 
                        name="password"
                        required>
                    
                    <input 
                        class="w-full px-4 md:px-5 rounded-full py-2.5 md:py-3 mt-2 bg-orange-600 text-white font-semibold hover:bg-orange-500 transition duration-300 transform hover:scale-105 cursor-pointer text-sm md:text-base active:scale-95" 
                        type="submit" 
                        value="Create My Account">
                </form>
            </div>
        </div>

        <!-- Divider Line - Vertical on desktop, Horizontal on mobile -->
        <div class="hidden md:block w-[1px] bg-gradient-to-b from-transparent via-zinc-700 to-transparent my-20"></div>
        <div class="md:hidden h-[1px] bg-gradient-to-r from-transparent via-zinc-700 to-transparent mx-4 my-4"></div>

        <!-- Login Section - Right Half / Bottom on Mobile -->
        <div class="w-full md:w-1/2 flex items-center justify-center min-h-[50vh] md:min-h-screen py-8 md:py-10">
            <div class="w-full max-w-md md:max-w-none md:px-8 lg:px-16 xl:px-32">
                <h4 class="text-lg sm:text-xl md:text-2xl capitalize mb-4 md:mb-5 text-white">Login your account</h4>
                
                <form autocomplete="off" action="/users/login" method="post">
                    <input 
                        class="block bg-zinc-800 w-full px-3 py-2.5 md:py-3 border-[1px] rounded-md mb-3 border-zinc-700 text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-transparent transition duration-300 text-sm md:text-base" 
                        type="email" 
                        placeholder="Email" 
                        name="email"
                        required>
                    
                    <input 
                        class="block bg-zinc-800 w-full px-3 py-2.5 md:py-3 border-[1px] rounded-md mb-3 border-zinc-700 text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-transparent transition duration-300 text-sm md:text-base" 
                        type="password" 
                        placeholder="Password" 
                        name="password"
                        required>
                    
                    <input 
                        class="w-full px-4 md:px-5 block rounded-full py-2.5 md:py-3 mt-2 bg-orange-600 text-white font-semibold hover:bg-orange-500 transition duration-300 transform hover:scale-105 cursor-pointer text-sm md:text-base active:scale-95" 
                        type="submit" 
                        value="Login">
                </form>

                <div class="mt-6 md:mt-8 text-center">
                    <p class="text-gray-500 text-xs sm:text-sm">Step into the world of exclusive sneakers 👟</p>
                </div>
            </div>
        </div>

    </div>

<%- include('./partials/footer') %>
