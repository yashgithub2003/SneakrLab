<%- include('./partials/header') %>

    <div class="w-full min-h-screen px-4 sm:px-8 lg:px-20 py-20 lg:py-24">
        <div class="max-w-4xl mx-auto">
            
            <!-- Success Animation -->
            <div class="text-center mb-8">
                <div class="inline-flex items-center justify-center w-20 h-20 bg-green-500/20 rounded-full mb-4 animate-bounce">
                    <i class="ri-check-line text-4xl text-green-400"></i>
                </div>
                <h1 class="text-3xl sm:text-4xl font-bold text-white mb-2">
                    Order Placed Successfully!
                </h1>
                <p class="text-gray-400 text-sm">Thank you for your purchase</p>
            </div>

            <!-- Order Details Card -->
            <div class="bg-zinc-800/60 backdrop-blur-sm rounded-lg border border-zinc-700 p-6 sm:p-8 shadow-xl mb-6">
                <div class="flex items-center justify-between mb-6 pb-4 border-b border-zinc-700">
                    <div>
                        <h2 class="text-xl font-bold text-white mb-1">
                            Order #<%= order._id.toString().slice(-8).toUpperCase() %>
                        </h2>
                        <p class="text-gray-400 text-sm">
                            Placed on <%= new Date(order.createdAt).toLocaleDateString('en-IN', { 
                                year: 'numeric', 
                                month: 'long', 
                                day: 'numeric' 
                            }) %>
                        </p>
                    </div>
                    <div class="text-right">
                        <span class="inline-block bg-orange-500/20 text-orange-400 px-4 py-2 rounded-full text-sm font-semibold">
                            <%= order.orderStatus %>
                        </span>
                    </div>
                </div>

                <!-- Order Items -->
                <div class="mb-6">
                    <h3 class="text-lg font-semibold text-white mb-4">
                        <i class="ri-shopping-bag-line mr-2 text-orange-500"></i>Order Items
                    </h3>
                    <div class="space-y-4">
                        <% order.items.forEach(function(item) { %>
                            <div class="flex items-center gap-4 p-4 bg-zinc-700/30 rounded-lg border border-zinc-700">
                                <img class="w-20 h-20 object-contain bg-zinc-700 rounded-md p-2" 
                                     src="data:image/jpeg;base64,<%= item.product.image.toString('base64') %>" 
                                     alt="<%= item.product.name %>">
                                <div class="flex-1">
                                    <h4 class="text-white font-semibold mb-1"><%= item.product.name %></h4>
                                    <div class="flex items-center gap-3 text-sm text-gray-400">
                                        <span>Size: <%= item.size %></span>
                                        <span>•</span>
                                        <span>Qty: <%= item.quantity %></span>
                                    </div>
                                </div>
                                <div class="text-right">
                                    <p class="text-orange-500 font-bold text-lg">₹ <%= item.price.toLocaleString('en-IN') %></p>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                </div>

                <!-- Shipping Address -->
                <div class="mb-6">
                    <h3 class="text-lg font-semibold text-white mb-4">
                        <i class="ri-map-pin-line mr-2 text-orange-500"></i>Shipping Address
                    </h3>
                    <div class="p-4 bg-zinc-700/30 rounded-lg border border-zinc-700">
                        <p class="text-white font-semibold mb-2"><%= order.shippingAddress.fullName %></p>
                        <p class="text-gray-400 text-sm"><%= order.shippingAddress.address %></p>
                        <p class="text-gray-400 text-sm">
                            <%= order.shippingAddress.city %>, <%= order.shippingAddress.postalCode %>
                        </p>
                        <p class="text-gray-400 text-sm"><%= order.shippingAddress.country %></p>
                    </div>
                </div>

                <!-- Payment & Total -->
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 mb-6">
                    <div>
                        <h3 class="text-lg font-semibold text-white mb-4">
                            <i class="ri-bank-card-line mr-2 text-orange-500"></i>Payment Method
                        </h3>
                        <div class="p-4 bg-zinc-700/30 rounded-lg border border-zinc-700">
                            <p class="text-white font-semibold">
                                <% if(order.paymentMethod === 'COD') { %>
                                    <i class="ri-money-rupee-circle-line mr-2"></i>Cash on Delivery
                                <% } else if(order.paymentMethod === 'CARD') { %>
                                    <i class="ri-bank-card-2-line mr-2"></i>Card Payment
                                <% } else if(order.paymentMethod === 'UPI') { %>
                                    <i class="ri-smartphone-line mr-2"></i>UPI Payment
                                <% } %>
                            </p>
                            <p class="text-gray-400 text-sm mt-1">
                                Status: 
                                <span class="<%= order.paymentStatus === 'PAID' ? 'text-green-400' : 'text-yellow-400' %> font-semibold">
                                    <%= order.paymentStatus %>
                                </span>
                            </p>
                        </div>
                    </div>

                    <div>
                        <h3 class="text-lg font-semibold text-white mb-4">
                            <i class="ri-money-rupee-circle-line mr-2 text-orange-500"></i>Total Amount
                        </h3>
                        <div class="p-4 bg-zinc-700/30 rounded-lg border border-zinc-700">
                            <p class="text-orange-500 font-bold text-3xl">₹ <%= order.totalAmount.toLocaleString('en-IN') %></p>
                            <p class="text-gray-400 text-sm mt-1">Including all taxes</p>
                        </div>
                    </div>
                </div>

                <!-- Expected Delivery -->
                <div class="p-4 bg-orange-500/10 border border-orange-500/30 rounded-lg">
                    <div class="flex items-start gap-3">
                        <i class="ri-truck-line text-orange-400 text-xl mt-1"></i>
                        <div>
                            <p class="text-orange-400 font-semibold mb-1">Expected Delivery</p>
                            <p class="text-gray-400 text-sm">
                                Your order will be delivered within 5-7 business days
                            </p>
                        </div>
                    </div>
                </div>

            </div>

            <!-- Action Buttons -->
            <div class="flex flex-col sm:flex-row gap-4 justify-center">
                <a href="/orders/<%= order._id %>" 
                   class="px-6 py-3 bg-orange-600 hover:bg-orange-500 text-white font-semibold rounded-lg transition duration-300 transform hover:scale-105 shadow-lg text-center">
                    <i class="ri-file-list-line mr-2"></i>View Order Details
                </a>
                <a href="/shop" 
                   class="px-6 py-3 bg-zinc-700 hover:bg-zinc-600 text-white font-semibold rounded-lg transition duration-300 text-center">
                    <i class="ri-shopping-bag-line mr-2"></i>Continue Shopping
                </a>
            </div>

        </div>
    </div>

<%- include('./partials/footer') %>
